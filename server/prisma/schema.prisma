// Prisma Schema — TaskFlow

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  password    String
  totalCoins  Int         @default(0)
  createdAt   DateTime    @default(now())

  tasks           Task[]
  userSkills      UserSkill[]
  focusSessions   FocusSession[]
  expenses        Expense[]
  incomes         Income[]
  budgets         Budget[]
  financialGoals  FinancialGoal[]
  subscriptions   Subscription[]
  habits          Habit[]
  workouts        Workout[]
  workoutSessions WorkoutSession[]
  bodyStats       BodyStat[]
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  notes        String?
  status       TaskStatus @default(TODO)
  dueDate      DateTime?
  rewardCoins  Int        @default(10)
  coinsAwarded Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtasks    Subtask[]
  attachments Attachment[]
  taskSkills  TaskSkill[]
  focusSessions FocusSession[]
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  taskId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  taskId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  icon      String
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now())

  taskSkills TaskSkill[]
  userSkills UserSkill[]
  habits     Habit[]
}

model UserSkill {
  id      String @id @default(cuid())
  userId  String
  skillId String
  xp      Int    @default(0)
  level   Int    @default(1)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model TaskSkill {
  id      String @id @default(cuid())
  taskId  String
  skillId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([taskId, skillId])
}

model FocusSession {
  id         String   @id @default(cuid())
  userId     String
  taskId     String
  duration   Int      @default(0)   // seconds actually focused
  note       String?                // post-session accomplishment note
  completed  Boolean  @default(false)
  bonusCoins Int      @default(0)   // streak milestone bonus awarded
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ── Personal Finance ──────────────────────────────────

model Expense {
  id        String   @id @default(cuid())
  userId    String
  title     String
  amount    Float
  category  String   @default("Other")
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Income {
  id        String   @id @default(cuid())
  userId    String
  source    String
  amount    Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id       String @id @default(cuid())
  userId   String
  category String
  limit    Float
  month    Int
  year     Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
}

model FinancialGoal {
  id            String   @id @default(cuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float    @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  serviceName     String
  amount          Float
  billingCycle    String   @default("monthly")
  nextPaymentDate DateTime
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Habit Tracking ────────────────────────────────────

enum HabitDifficulty {
  EASY
  MEDIUM
  HARD
}

model Habit {
  id            String          @id @default(cuid())
  userId        String
  title         String
  category      String          @default("General")
  skillId       String?
  difficulty    HabitDifficulty @default(MEDIUM)
  currentStreak Int             @default(0)
  bestStreak    Int             @default(0)
  createdAt     DateTime        @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill       Skill?            @relation(fields: [skillId], references: [id], onDelete: SetNull)
  completions HabitCompletion[]
}

model HabitCompletion {
  id      String   @id @default(cuid())
  habitId String
  date    DateTime // UTC midnight for the day

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

// ── Gym / Fitness ──────────────────────────────────────

model GymExercise {
  id          String  @id @default(cuid())
  name        String  @unique
  muscleGroup String
  description String?

  workoutExercises WorkoutExercise[]
  sessionSets      SessionSet[]
}

model Workout {
  id        String   @id @default(cuid())
  userId    String
  title     String
  dayOfWeek String?  // "Monday", "Tuesday", etc.
  createdAt DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  sessions  WorkoutSession[]
}

model WorkoutExercise {
  id         String @id @default(cuid())
  workoutId  String
  exerciseId String
  sets       Int    @default(3)
  reps       Int    @default(10)
  weight     Float?
  order      Int    @default(0)

  workout  Workout     @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise GymExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutId, exerciseId])
}

model WorkoutSession {
  id          String   @id @default(cuid())
  userId      String
  workoutId   String?
  date        DateTime @default(now())
  completed   Boolean  @default(false)
  durationMin Int?
  notes       String?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout Workout?      @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  sets    SessionSet[]
}

model SessionSet {
  id         String  @id @default(cuid())
  sessionId  String
  exerciseId String
  setNumber  Int
  reps       Int?
  weight     Float?
  completed  Boolean @default(false)

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise GymExercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model BodyStat {
  id        String   @id @default(cuid())
  userId    String
  weight    Float?
  bodyFat   Float?
  chest     Float?
  arms      Float?
  waist     Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
