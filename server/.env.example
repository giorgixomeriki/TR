# ── Database ────────────────────────────────────────────
# Railway PostgreSQL: copy the DATABASE_URL from the Railway Postgres plugin
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/railway?schema=public"

# ── Auth ─────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-strong-random-secret-min-32-chars"

# ── Server ───────────────────────────────────────────────
# Railway injects PORT automatically — do not hardcode in production.
PORT=3000
NODE_ENV=production

# ── Frontend ─────────────────────────────────────────────
# Set to your deployed frontend URL (Vercel / Netlify / Railway static)
CLIENT_URL="https://your-frontend-domain.com"

# ── AI Advisor (optional) ────────────────────────────────
# Obtain from https://console.anthropic.com
# If empty, /api/ai endpoints return 503 gracefully — app still works.
ANTHROPIC_API_KEY=""
